import os
from pathlib import Path
from concurrent.futures import ProcessPoolExecutor
from .base_scanner import BaseScanner

class FullScanner(BaseScanner):
    def __init__(self, target_dir, method_file_path):
        super().__init__(method_file_path)
        self.target_dir = Path(target_dir)

    def scan(self):
        results = {}
        valid_files = []

        # 1. 파일 목록 수집 및 필터링 (가장 먼저 수행)
        # os.walk를 쓰되, Path 객체와 결합하여 효율적으로 목록을 뽑습니다.
        for root, dirs, files in os.walk(self.target_dir):
            # 무시할 폴더는 아예 들어가지 않도록 가지치기 (기존 로직 유지)
            dirs[:] = [d for d in dirs if d not in self.ignore_dirs]

            for file in files:
                file_path = Path(root) / file

                # 확장자 체크
                if file_path.suffix.lower() in self.ignore_exts:
                    continue

                # 특정 파일명 체크
                if file_path.name in ("pii_methods.txt", ".cfinfo"):
                    continue

                # 검사 대상 리스트에 추가
                valid_files.append(file_path)

        if not valid_files:
            return results

        # 2. 병렬 실행 (ProcessPoolExecutor)
        # 수집된 모든 파일을 CPU 코어들에 분산 배치하여 검사합니다.
        with ProcessPoolExecutor() as executor:
            # map을 통해 각 파일에 대해 _scan_file을 호출합니다.
            all_findings = list(executor.map(self._scan_file, valid_files))

        # 3. 결과 데이터 재구성 (파일 경로 : 발견 사항)
        for file_path, file_results in zip(valid_files, all_findings):
            if file_results:
                results[str(file_path)] = file_results

        return results


