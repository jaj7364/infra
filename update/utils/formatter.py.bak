from typing import Dict, List, Any

def print_results(results: Dict[str, List[Dict[str, Any]]], summary_only: bool = False) -> int:
    """
    스캔 결과를 터미널에 예쁘게 출력하고 총 발견 건수를 반환합니다.
    """
    # 1. 터미널 색상 정의 (색상이 있으면 가독성이 200% 올라갑니다)
    GREEN = "\033[92m"
    YELLOW = "\033[93m"
    RED = "\033[91m"
    CYAN = "\033[96m"
    RESET = "\033[0m"
    BOLD = "\033[1m"

    total_methods = 0
    total_regex = 0

    # 2. 결과 출력 로직
    for file_path, findings in results.items():
        if not summary_only:
            print(f"\n{CYAN}{BOLD}📄 {file_path}{RESET}")

        for finding in findings:
            # 유형 분류 (사전탐지 여부 확인)
            is_method = "사전탐지" in finding['type']

            if is_method:
                total_methods += 1
            else:
                total_regex += 1

            # 상세 내역 출력 (summary_only가 아닐 때만)
            if not summary_only:
                color = YELLOW if is_method else RED
                # :>3 은 행 번호를 3자리 우측 정렬하여 줄 맞춤을 해줍니다.
                print(f"  {color}↳ [Line {finding['line']:>3}]{RESET} {finding['type']}: {finding['matches']}")

    # 3. 최종 요약 블록 (가장 시인성이 좋아야 함)
    status_color = RED if (total_methods + total_regex) > 0 else GREEN

    print(f"\n{status_color}{'=' * 50}")
    print(f"{BOLD}[!] 개인정보 의심 항목 탐지 결과{RESET}")
    print(f"    - 민감 메소드 의심: {total_methods}건")
    print(f"    - 하드코딩 개인정보 의심: {total_regex}건")
    print(f"{status_color}{'=' * 50}{RESET}")

    return total_methods + total_regex